# Copy this to .env and adjust as needed

# Camera
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=20
FRAME_SKIP=2

# Detection
YOLO_MODEL=yolov8n-face.pt
YOLO_CONF=0.45

# Face Recognition
FACE_RECOGNITION_TOLERANCE=0.55

# Eye / Head Pose
EAR_THRESHOLD=0.25
YAW_THRESHOLD=20.0
PITCH_THRESHOLD=20.0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000

# Dashboard
DASHBOARD_REFRESH_SECS=3

# Logging
LOG_LEVEL=INFO

# GPU (set to true to force CPU-only mode)
FORCE_CPU=false
